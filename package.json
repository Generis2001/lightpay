{
  "name": "lightpay",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "mobile": "turbo run dev --filter=@lightpay/mobile",
    "gateway": "turbo run dev --filter=@lightpay/gateway",
    "services": "turbo run dev --filter='./services/*'",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.5"
  },
  "packageManager": "yarn@4.6.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
