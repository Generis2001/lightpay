# LightPay Environment Variables — Copy to .env.local and fill in values

# === Database ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lightpay
POSTGRES_PASSWORD=lightpay_dev_secret
POSTGRES_DB=lightpay

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=lightpay_redis_secret

# === Auth Service ===
JWT_SECRET=change-me-to-a-secure-random-256-bit-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
PIN_MAX_ATTEMPTS=5

# === SMS (Termii) ===
TERMII_API_KEY=
TERMII_SENDER_ID=LightPay

# === Email (SendGrid) ===
SENDGRID_API_KEY=
FROM_EMAIL=noreply@lightpay.ng

# === Paystack ===
PAYSTACK_SECRET_KEY=sk_test_xxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxx

# === VTPass (Bills) ===
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=

# === Mobile App ===
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_APP_VERSION=1.0.0

# === Ports ===
GATEWAY_PORT=3000
AUTH_PORT=3001
FIAT_PORT=3002
CRYPTO_PORT=3003
KYC_PORT=3004
NOTIFICATIONS_PORT=3005
